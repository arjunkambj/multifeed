{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NODE_ENV",
    "NEXT_PUBLIC_HEXCLAVE_PROJECT_ID",
    "NEXT_PUBLIC_HEXCLAVE_PUBLISHABLE_CLIENT_KEY",
    "NEXT_PUBLIC_CONVEX_URL",
    "NEXT_PUBLIC_APP_URL",
    "HEXCLAVE_SECRET_SERVER_KEY",
    "HEXCLAVE_WEBHOOK_SECRET",
    "APP_ORIGIN",
    "OAUTH_REDIRECT_URI",
    "OAUTH_SERVER_SECRET",
    "DODO_PAYMENTS_API_KEY",
    "DODO_PAYMENTS_ENVIRONMENT",
    "DODO_PAYMENTS_WEBHOOK_KEY",
    "DODO_CREATOR_MONTHLY_PRODUCT_ID",
    "DODO_CREATOR_YEARLY_PRODUCT_ID",
    "DODO_GROWTH_MONTHLY_PRODUCT_ID",
    "DODO_GROWTH_YEARLY_PRODUCT_ID",
    "DODO_AGENCY_MONTHLY_PRODUCT_ID",
    "DODO_AGENCY_YEARLY_PRODUCT_ID",
    "META_APP_ID",
    "META_APP_SECRET",
    "META_FACEBOOK_CONFIG_ID",
    "META_INSTAGRAM_CONFIG_ID",
    "THREADS_APP_ID",
    "THREADS_APP_SECRET",
    "LINKEDIN_CLIENT_ID",
    "LINKEDIN_CLIENT_SECRET",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "TIKTOK_CLIENT_KEY",
    "TIKTOK_CLIENT_SECRET",
    "X_CLIENT_ID",
    "X_CLIENT_SECRET",
    "TOKEN_ENCRYPTION_KEY",
    "BILLING_SOFT_LIMITS",
    "R2_BUCKET",
    "R2_ENDPOINT",
    "R2_ACCESS_KEY_ID",
    "R2_SECRET_ACCESS_KEY",
    "R2_TOKEN",
    "CONVEX_DEPLOYMENT",
    "CONVEX_URL",
    "CONVEX_SITE_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
