{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NEXT_PUBLIC_HEXCLAVE_PROJECT_ID",
    "NEXT_PUBLIC_HEXCLAVE_PUBLISHABLE_CLIENT_KEY",
    "NEXT_PUBLIC_CONVEX_URL",
    "HEXCLAVE_SECRET_SERVER_KEY",
    "HEXCLAVE_WEBHOOK_SECRET",
    "NEXT_PUBLIC_APP_URL",
    "DODO_PAYMENTS_API_KEY",
    "DODO_PAYMENTS_ENVIRONMENT",
    "DODO_PAYMENTS_WEBHOOK_KEY",
    "DODO_CREATOR_MONTHLY_PRODUCT_ID",
    "DODO_CREATOR_YEARLY_PRODUCT_ID",
    "DODO_GROWTH_MONTHLY_PRODUCT_ID",
    "DODO_GROWTH_YEARLY_PRODUCT_ID",
    "DODO_AGENCY_MONTHLY_PRODUCT_ID",
    "DODO_AGENCY_YEARLY_PRODUCT_ID"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
