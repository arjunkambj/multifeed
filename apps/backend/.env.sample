# =============================================================================
# apps/backend — Convex env
# =============================================================================
# Two layers:
#
# 1) Local CLI file (this pattern → .env.local)
#    Written/used by `npx convex dev`. Safe to copy then fill.
#    cp apps/backend/.env.sample apps/backend/.env.local
#
# 2) Convex deployment env (functions at runtime)
#    Set with:  cd apps/backend && npx convex env set NAME value
#    Or Convex Dashboard → Settings → Environment Variables
#
# Variables under "Convex deployment env" MUST be set on the deployment —
# putting them only in .env.local is not enough for production, and for
# local `convex dev` the CLI syncs dashboard/env-set values into the
# running backend. Prefer `npx convex env set` for secrets used in convex/.
# =============================================================================

# -----------------------------------------------------------------------------
# Local CLI (auto-filled by `npx convex dev` after first link)
# -----------------------------------------------------------------------------

# e.g. dev:your-team-your-project-xyz | prod:your-team-your-project-xyz
CONVEX_DEPLOYMENT=

# Same values as the dashboard; web needs NEXT_PUBLIC_CONVEX_URL = CONVEX_URL
CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_SITE_URL=https://your-deployment.convex.site

# -----------------------------------------------------------------------------
# Convex deployment env — required for auth + token crypto
#   npx convex env set NEXT_PUBLIC_HEXCLAVE_PROJECT_ID "..."
#   npx convex env set TOKEN_ENCRYPTION_KEY "$(openssl rand -hex 32)"
#   npx convex env set OAUTH_SERVER_SECRET "$(openssl rand -hex 32)"
# -----------------------------------------------------------------------------

# Must match web NEXT_PUBLIC_HEXCLAVE_PROJECT_ID (used in convex/auth.config.ts)
NEXT_PUBLIC_HEXCLAVE_PROJECT_ID=

# AES-256-GCM key for connected-account tokens (32 bytes: 64-char hex OR base64)
# Generate: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# Must exactly match apps/web OAUTH_SERVER_SECRET.
OAUTH_SERVER_SECRET=

# -----------------------------------------------------------------------------
# Convex deployment env — billing webhooks (Dodo → Convex HTTP)
# Webhook URL: https://<CONVEX_SITE_URL>/webhook/dodopayment
# -----------------------------------------------------------------------------

DODO_PAYMENTS_WEBHOOK_KEY=

# Optional Hexclave webhook secret if you wire Hexclave → Convex HTTP
# HEXCLAVE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Convex deployment env — plan limits
# -----------------------------------------------------------------------------

# Default: soft creator limit when no subscription (good for local/dev).
# Production: set to "false" to require an active billing subscription.
# BILLING_SOFT_LIMITS=false

# -----------------------------------------------------------------------------
# Convex deployment env — Cloudflare R2 media (@convex-dev/r2)
# Only needed when enabling media upload.
# -----------------------------------------------------------------------------

# R2_BUCKET=
# R2_ENDPOINT=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_TOKEN=

# =============================================================================
# Quick setup commands (from apps/backend)
# =============================================================================
#
# npx convex dev
# npx convex env set NEXT_PUBLIC_HEXCLAVE_PROJECT_ID "your-project-id"
# npx convex env set TOKEN_ENCRYPTION_KEY "$(openssl rand -hex 32)"
# npx convex env set OAUTH_SERVER_SECRET "the-same-value-used-by-apps-web"
# npx convex env set DODO_PAYMENTS_WEBHOOK_KEY "whsec_..."
# npx convex env set BILLING_SOFT_LIMITS false   # prod only
#
# R2 (optional):
# npx convex env set R2_BUCKET "..."
# npx convex env set R2_ENDPOINT "https://....r2.cloudflarestorage.com"
# npx convex env set R2_ACCESS_KEY_ID "..."
# npx convex env set R2_SECRET_ACCESS_KEY "..."
# npx convex env set R2_TOKEN "..."
#
# List: npx convex env list
# =============================================================================
