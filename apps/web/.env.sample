# =============================================================================
# apps/web — Next.js env
# =============================================================================
# Copy to .env.local:
#   cp apps/web/.env.sample apps/web/.env.local
#
# Restart `pnpm --filter @multifeed/web dev` after changes.
# NEXT_PUBLIC_* vars are exposed to the browser — never put secrets there.
# =============================================================================

# -----------------------------------------------------------------------------
# Required — app core
# -----------------------------------------------------------------------------

# Convex deployment URL (Dashboard → Settings → URL, or from apps/backend `.env.local`)
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Public site origin (OAuth redirects, absolute links). Local default if omitted: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional override for server-side origin (defaults to NEXT_PUBLIC_APP_URL)
# APP_ORIGIN=http://localhost:3000

# Optional full OAuth callback override (defaults to {APP_ORIGIN}/api/oauth/callback).
# Local providers that require HTTPS can use the apps/oauth-relay Worker URL.
# OAUTH_REDIRECT_URI=http://localhost:3000/api/oauth/callback

# Shared with the Convex deployment; authorizes server-only OAuth mutations.
# Generate once with: openssl rand -hex 32
OAUTH_SERVER_SECRET=

# -----------------------------------------------------------------------------
# Required — Hexclave auth
# -----------------------------------------------------------------------------

NEXT_PUBLIC_HEXCLAVE_PROJECT_ID=
NEXT_PUBLIC_HEXCLAVE_PUBLISHABLE_CLIENT_KEY=
HEXCLAVE_SECRET_SERVER_KEY=

# -----------------------------------------------------------------------------
# Billing — Dodo Payments (checkout API routes)
# -----------------------------------------------------------------------------

DODO_PAYMENTS_API_KEY=
# test_mode | live_mode
DODO_PAYMENTS_ENVIRONMENT=test_mode

DODO_CREATOR_MONTHLY_PRODUCT_ID=
DODO_CREATOR_YEARLY_PRODUCT_ID=
DODO_GROWTH_MONTHLY_PRODUCT_ID=
DODO_GROWTH_YEARLY_PRODUCT_ID=
DODO_AGENCY_MONTHLY_PRODUCT_ID=
DODO_AGENCY_YEARLY_PRODUCT_ID=

# -----------------------------------------------------------------------------
# OAuth provider credentials (server-only — Next.js API routes)
# Register redirect URI on every provider console:
#   http://localhost:3000/api/oauth/callback (or the HTTPS relay for local work)
#   https://themultifeed.com/api/oauth/callback
# Only set the platforms you actually enable.
# -----------------------------------------------------------------------------

# Meta — Facebook Pages and Instagram via Facebook Login
META_APP_ID=
META_APP_SECRET=
# Facebook Login for Business configuration IDs (User access token type)
META_FACEBOOK_CONFIG_ID=
META_INSTAGRAM_CONFIG_ID=

# Threads uses its own App ID and App Secret from the Threads use case.
THREADS_APP_ID=
THREADS_APP_SECRET=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Google — YouTube
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# TikTok — Login Kit + Content Posting API
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# X (Twitter) — PKCE; client secret optional depending on app type
X_CLIENT_ID=
X_CLIENT_SECRET=
